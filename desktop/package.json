{
  "name": "@glib-code/desktop",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun run build && electron .",
    "build": "tsc -p tsconfig.json",
    "build:local": "tsc -p tsconfig.json && electron-builder --dir --mac",
    "build:local:win": "tsc -p tsconfig.json && electron-builder --dir --win",
    "build:win": "tsc -p tsconfig.json && electron-builder --win nsis --publish always",
    "build:dmg": "tsc -p tsconfig.json && electron-builder --mac dmg --publish always",
    "build:linux": "tsc -p tsconfig.json && electron-builder --linux AppImage deb --publish always",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "bun-types": "^1.3.1",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "dev.glibcode.app",
    "productName": "glib-code",
    "directories": {
      "output": "dist-app"
    },
    "files": ["dist/**"],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../server",
        "to": "server",
        "filter": ["**/*", "!node_modules"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "cloudboy-jh",
        "repo": "glib-code"
      }
    ],
    "mac": {
      "identity": null,
      "icon": "assets/icon.iconset/icon_1024x1024.png",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "target": [
        {
          "target": "dir"
        },
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "assets/icon.iconset/icon_1024x1024.png",
      "background": "assets/dmg-background.png",
      "iconSize": 128,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 200,
          "type": "file"
        },
        {
          "x": 480,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "assets/icon.iconset/icon_256x256.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.iconset/icon_256x256.png",
      "uninstallerIcon": "assets/icon.iconset/icon_256x256.png",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "icon": "assets/icon.iconset/icon_512x512.png",
      "target": [
        {
          "target": "AppImage"
        },
        {
          "target": "deb"
        }
      ],
      "category": "Development"
    }
  }
}
