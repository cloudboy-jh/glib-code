{
  "name": "@glib-code/desktop",
  "version": "0.1.5",
  "description": "AI coding agent — review diffs, run sessions, ship faster.",
  "homepage": "https://github.com/cloudboy-jh/glib-code",
  "author": {
    "name": "Glib Code, Inc.",
    "email": "support@glibcode.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun run build && electron .",
    "build": "tsc -p tsconfig.json",
    "build:local": "tsc -p tsconfig.json && electron-builder --dir --mac",
    "build:local:win": "tsc -p tsconfig.json && electron-builder --dir --win",
    "build:win": "electron-builder --win nsis --publish always",
    "build:dmg": "electron-builder --mac dmg --publish always",
    "build:linux": "electron-builder --linux AppImage deb --publish always",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "bun-types": "^1.3.1",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "dev.glibcode.app",
    "productName": "glib-code",
    "electronVersion": "35.1.4",
    "directories": {
      "output": "dist-app"
    },
    "files": ["dist/**"],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../server/dist",
        "to": "server",
        "filter": ["**/*", "!node_modules/.cache"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "cloudboy-jh",
        "repo": "glib-code",
        "releaseType": "release"
      }
    ],
    "mac": {
      "identity": null,
      "icon": "assets/icon.iconset/icon_1024x1024.png",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "target": [
        {
          "target": "dir"
        },
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "assets/icon.iconset/icon_1024x1024.png",
      "iconSize": 128,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 200,
          "type": "file"
        },
        {
          "x": 480,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.iconset/icon_512x512.png",
      "maintainer": "Glib Code, Inc. <support@glibcode.com>",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage"
        },
        {
          "target": "deb"
        }
      ],
      "category": "Development"
    }
  }
}
