{
  "name": "@glib-code/desktop",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun run build && electron .",
    "build": "tsc -p tsconfig.json",
    "build:local": "tsc -p tsconfig.json && electron-builder --dir --mac",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "bun-types": "^1.3.1",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "dev.glibcode.app",
    "productName": "glib-code",
    "directories": { "output": "dist-app" },
    "files": ["dist/**"],
    "extraResources": [
      { "from": "../web/dist", "to": "web/dist", "filter": ["**/*"] },
      { "from": "../server", "to": "server", "filter": ["**/*", "!node_modules"] }
    ],
    "mac": {
      "identity": null,
      "icon": "assets/icon.iconset/icon_1024x1024.png",
      "target": [{ "target": "dir" }]
    }
  }
}
